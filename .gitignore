# Dependency directories
# Contains packages installed by npm. These should never be checked into version control.
node_modules/

# Environment files
# Contains sensitive credentials like API keys and database URLs. Never commit these files.
.env
.env.*
.env.local
.env.production
.env.development
.env.development.local
.env.production.local
!.env.example
.envrc
secrets.*
*.pem
*.key

# Next.js build output
# Automatically generated when building Next.js apps.
.next/

# Build and distribution directories
# Compiled production code that can be rebuilt at runtime.
dist/
build/

# Coverage directory
# Created by test suites displaying code coverage statistics.
coverage/

# Vercel deployment folder
# Stores local deployment cache and project identifiers.
.vercel/

# Log files
# Generated by applications and package managers during runtime.
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Operating System files
# System-specific metadata files that don't belong in the repo.
.DS_Store
Thumbs.db
