# ==============================================================================
# CareerCraft AI - Environment Variables Template (.env.example)
# Copy this file to `.env` and fill in the values. NEVER commit `.env` to git.
# ==============================================================================

# ─── Gemini API Configuration ────────────────────────────────────────────────
# Get your free Gemini API key at: https://aistudio.google.com/app/apikey
# Used for resume rewriting, cover letter generation, and interview questions.
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Server Configuration ─────────────────────────────────────────────────────
# The port the local express server runs on (default is 3000).
PORT=3000

# ─── Supabase Configuration ───────────────────────────────────────────────────
# Find these in your Supabase Project Dashboard under Settings > API
# The public API URL of your Supabase instance.
SUPABASE_URL=your_supabase_url_here

# The public client key. Safe to expose client-side when Row-Level Security (RLS) is active.
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# High-privileged secret bypass key. Bypasses Row-Level Security (RLS).
# WARNING: Only set this on the server, NEVER expose this to the client side.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Razorpay Configuration (Payments) ───────────────────────────────────────
# Find these in your Razorpay Dashboard under Account & Settings > API Keys
# The public key identifier used to load the payment gateway in the frontend.
RAZORPAY_KEY_ID=your_razorpay_key_id_here

# The private key secret used to generate HMAC signatures and verify payments.
# WARNING: Keep this strictly confidential on the server side.
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
