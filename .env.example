# Get your free Gemini API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: change the local server port (default: 3000)
PORT=3000

# Supabase credentials — required for user auth, usage tracking and email history
# Find these in your Supabase project dashboard under Settings > API
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
# Service role key bypasses Row-Level Security — only set this on the server, never expose it client-side
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
